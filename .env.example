# Docker PostgreSQL configuration
POSTGRES_USER="timeclock_user"
POSTGRES_PASSWORD="replace-with-a-strong-database-password"
POSTGRES_DB="timeclock_db"

# Database connection string (PostgreSQL)
# Use HOST=postgres for Docker Compose production deploys.
DATABASE_URL="postgresql://timeclock_user:replace-with-a-strong-database-password@postgres:5432/timeclock_db?schema=public"

# NextAuth.js configuration
NEXTAUTH_SECRET="generate-a-real-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.com"

# Optional seed admin account values.
# Set these before running `npm run seed` on a production server.
ADMIN_EMAIL="admin@mckbyte.local"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-strong-admin-pin"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="User"
