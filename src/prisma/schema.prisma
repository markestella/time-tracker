generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  username  String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clockEvents ClockEvent[]
  messages    Message[]
  tasks       Task[]
}

model ClockEvent {
  id        Int      @id @default(autoincrement())
  type      String
  timestamp DateTime @default(now())
  userId    Int
  taskId    Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  message   Message?
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockEvents ClockEvent[]
}

model Message {
  id           Int        @id @default(autoincrement())
  content      String
  clockEventId Int        @unique
  createdAt    DateTime   @default(now())
  userId       Int
  isRead       Boolean    @default(false)
  clockEvent   ClockEvent @relation(fields: [clockEventId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions    Question[]
}

model Question {
  id           Int      @id @default(autoincrement())
  content      String
  answer       String?
  createdAt    DateTime @default(now())
  messageId    Int
  isReadByUser Boolean  @default(false)
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model QuoteOfTheDay {
  id        Int      @id @default(autoincrement())
  quote     String
  author    String
  date      DateTime @unique
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
